<Project Sdk="Microsoft.NET.Sdk">

    <!--
      Aggregate policy (LiteBus meta-package):
      - Includes core mediators (Commands, Queries, Events, Messaging) and inbox/outbox orchestration with abstractions.
      - Storage adapters (PostgreSQL, EF Core, InMemory), dispatch adapters (Commands, Events, AMQP),
        ingress (AMQP), LiteBus.Amqp, LiteBus.Analyzers, and runtime/DI extension packages remain separate NuGet packages.
    -->

    <ItemGroup>
        <ProjectReference Include="..\LiteBus.Commands.Abstractions\LiteBus.Commands.Abstractions.csproj"/>
        <ProjectReference Include="..\LiteBus.Commands\LiteBus.Commands.csproj"/>
        <ProjectReference Include="..\LiteBus.Events.Abstractions\LiteBus.Events.Abstractions.csproj"/>
        <ProjectReference Include="..\LiteBus.Events\LiteBus.Events.csproj"/>
        <ProjectReference Include="..\LiteBus.Inbox.Abstractions\LiteBus.Inbox.Abstractions.csproj"/>
        <ProjectReference Include="..\LiteBus.Inbox\LiteBus.Inbox.csproj"/>
        <ProjectReference Include="..\LiteBus.Messaging.Abstractions\LiteBus.Messaging.Abstractions.csproj"/>
        <ProjectReference Include="..\LiteBus.Messaging\LiteBus.Messaging.csproj"/>
        <ProjectReference Include="..\LiteBus.Outbox.Abstractions\LiteBus.Outbox.Abstractions.csproj"/>
        <ProjectReference Include="..\LiteBus.Outbox\LiteBus.Outbox.csproj"/>
        <ProjectReference Include="..\LiteBus.Queries.Abstractions\LiteBus.Queries.Abstractions.csproj"/>
        <ProjectReference Include="..\LiteBus.Queries\LiteBus.Queries.csproj"/>
    </ItemGroup>

</Project>
